{
  "name": "local-scanner-agent",
  "version": "1.0.0",
  "description": "Local NAPS2 scanner agent for Maptech DMS — bridges local scanner hardware with cloud backend",
  "main": "server.js",
  "bin": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "build": "pkg . --target node18-win-x64 --output scanner-agent.exe"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "form-data": "^4.0.1",
    "uuid": "^11.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "pkg": "^5.8.1"
  },
  "pkg": {
    "targets": [
      "node18-win-x64"
    ],
    "assets": [
      "scans/**/*",
      "naps2*.exe",
      "NAPS2*.exe"
    ]
  }
}
