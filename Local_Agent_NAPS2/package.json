{
  "name": "local-scanner-agent",
  "version": "1.0.0",
  "description": "Local NAPS2 scanner agent for Maptech DMS — bridges local scanner hardware with cloud backend",
  "main": "electron-main.js",
  "bin": "server.js",
  "scripts": {
    "start": "electron .",
    "start:server": "node server.js",
    "dev": "electron .",
    "dev:server": "node --watch server.js",
    "build": "electron-builder --win dir",
    "build:installer": "node build-installer.js"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "form-data": "^4.0.1",
    "uuid": "^11.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "electron": "^35.1.4",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "com.maptech.scanneragent",
    "productName": "Scanner Agent",
    "directories": {
      "output": "dist"
    },
    "files": [
      "assets/**/*",
      "build-installer.js",
      "electron-main.js",
      "logger.js",
      "server.js",
      "package.json"
    ],
    "win": {
      "target": [
        "dir"
      ],
      "icon": "assets/scanner-agent.ico",
      "executableName": "scanner-agent",
      "signAndEditExecutable": false
    }
  }
}
